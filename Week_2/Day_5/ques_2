class Solution {
    public int compress(char[] chars) {

        int writeIndex=0;
        int readIndex=0;

        while(readIndex<chars.length) {

            char currentCharacter=chars[readIndex];
            int count=0;

            while(readIndex<chars.length &&
                  chars[readIndex]==currentCharacter) {

                count++;
                readIndex++;
            }

            chars[writeIndex]=currentCharacter;
            writeIndex++;

            if(count>1) {

                String countString=String.valueOf(count);

                for(int i=0;i<countString.length();i++) {
                    chars[writeIndex]=countString.charAt(i);
                    writeIndex++;
                }
            }
        }

        return writeIndex;
    }
}