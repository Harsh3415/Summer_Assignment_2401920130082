class Solution {
    public boolean repeatedSubstringPattern(String s) {

        int stringLength=s.length();

        for(int substringLength=1;substringLength<=stringLength/2;substringLength++) {

            if(stringLength%substringLength==0) {

                String part=s.substring(0,substringLength);

                String repeatedString="";

                int repeatCount=stringLength/substringLength;

                for(int i=0;i<repeatCount;i++) {
                    repeatedString+=part;
                }

                if(repeatedString.equals(s)) {
                    return true;
                }
            }
        }

        return false;
    }
}